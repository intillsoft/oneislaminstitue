# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ============================================================================
# STRIPE PAYMENT PROCESSING (Required for Subscriptions)
# ============================================================================
# Get keys: https://stripe.com/ → Developers → API Keys
# Get webhook secret: Developers → Webhooks → Add endpoint → Copy signing secret
# Create products: Products → Add product → Copy Price IDs
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_FREE=price_free_plan
STRIPE_PRICE_ID_PROFESSIONAL=price_professional_plan
STRIPE_PRICE_ID_PREMIUM=price_premium_plan
STRIPE_PRICE_ID_RECRUITER=price_recruiter_plan

# ============================================================================
# EMAIL NOTIFICATION SERVICE (Choose ONE)
# ============================================================================

# Option A: SendGrid (Recommended - 100 emails/day FREE)
# Get key: https://sendgrid.com/ → Settings → API Keys → Create API Key
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Workflow

# Option B: Resend (Alternative - 3,000 emails/month FREE)
# Get key: https://resend.com/ → API Keys → Create API Key
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Workflow <noreply@yourdomain.com>

# ============================================================================
# SMS NOTIFICATION SERVICE (Choose ONE)
# ============================================================================

# Option A: Twilio (Recommended - $15.50 FREE trial credit)
# Get credentials: https://www.twilio.com/ → Console Dashboard
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Option B: AWS SNS (Alternative)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1

# Application Configuration
FRONTEND_URL=http://localhost:3000
PORT=3001
NODE_ENV=development

# Logging
LOG_LEVEL=info

# OpenAI Configuration (REQUIRED for AI features)
OPENAI_API_KEY=sk-your_openai_api_key_here