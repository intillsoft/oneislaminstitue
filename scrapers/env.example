# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=job_scraper_db
DB_USER=postgres
DB_PASSWORD=your_password

# Proxy Configuration (optional)
PROXY_LIST=http://proxy1:port,http://proxy2:port
USE_PROXY=false

# Rate Limiting
RATE_LIMIT_DELAY_MIN=2000
RATE_LIMIT_DELAY_MAX=5000

# LinkedIn API (if using API instead of scraping)
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token

# Scraper Settings
HEADLESS=true
TIMEOUT=30000
MAX_RETRIES=3

# Logging
LOG_LEVEL=info

# Scheduler Settings
RUN_ON_START=false

# Scraper-specific options
INDEED_TITLE=software engineer
INDEED_LOCATION=
INDEED_MAX_PAGES=5

LINKEDIN_KEYWORDS=developer
LINKEDIN_LOCATION=
LINKEDIN_MAX_PAGES=5

GLASSDOOR_COMPANIES=Google,Microsoft,Apple

